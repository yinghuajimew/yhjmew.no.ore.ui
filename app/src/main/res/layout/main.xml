<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- 右上角按钮组 -->
    <LinearLayout
        android:id="@+id/top_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_alignParentTop="true"
        android:layout_margin="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/btn_about"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_black_border"
            android:paddingLeft="12dp"
            android:paddingTop="6dp"
            android:paddingRight="12dp"
            android:paddingBottom="6dp"
            android:text="@string/about"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/btn_sign_config"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_black_border"
            android:paddingLeft="12dp"
            android:paddingTop="6dp"
            android:paddingRight="12dp"
            android:paddingBottom="6dp"
            android:text="@string/signature_settings"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 原本居中的所有内容 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical">

        <!-- 顶部的两个按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_select_mc"
                android:layout_width="130dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_black_border"
                android:text="@string/normal_processing"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginRight="10dp" />

            <Button
                android:id="@+id/btn_make_clone"
                android:layout_width="130dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_black_border"
                android:text="@string/coexistence_processing"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginLeft="10dp" />
        </LinearLayout>

        <!-- 进度百分比文本 -->
        <TextView
            android:id="@+id/tv_progress_percent"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:gravity="right"
            android:text="@string/waiting_to_begin"
            android:textColor="#000000"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- 黑色进度条 -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#000000" />

        <!-- 下方的日志输出区域 -->
        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:background="@drawable/bg_black_border"
            android:padding="8dp"
            android:orientation="vertical">

            <ScrollView
                android:id="@+id/scroll_view_log"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/tv_log_output"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/log_output_ready"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textIsSelectable="true" />
            </ScrollView>
        </LinearLayout>

    </LinearLayout>
</RelativeLayout>